<Window x:Class="WPF_projekt_lolko.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:WPF_projekt_lolko"
        Title="Evidence Championů" Height="450" Width="800">

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- TABULKA -->
        <DataGrid x:Name="dgChampioni"
                  Grid.Column="0"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Jméno" Binding="{Binding Jmeno}" Width="*"/>
                <DataGridTextColumn Header="Role" Binding="{Binding Role}" Width="100"/>
                <DataGridTextColumn Header="Region" Binding="{Binding Region}" Width="120"/>
                <DataGridTextColumn Header="Winrate" Binding="{Binding Winrate}" Width="100"/>
                <DataGridCheckBoxColumn Header="Odemčený" Binding="{Binding JeOdemceny}" Width="100"/>
            </DataGrid.Columns>
        </DataGrid>

        <!-- FORMULÁŘ -->
        <StackPanel Grid.Column="1" Margin="10">

            <TextBlock Text="Jméno"/>
            <TextBox x:Name="txtJmeno" Margin="0,5"/>

            <TextBlock Text="Role"/>
            <TextBox x:Name="txtRole" Margin="0,5"/>

            <TextBlock Text="Winrate"/>
            <TextBox x:Name="txtWinrate" Margin="0,5"/>

            <TextBlock Text="Region"/>
            <ComboBox x:Name="cbRegion" Margin="0,5"/>

            <CheckBox x:Name="chkOdemceny" Content="Odemčený" Margin="0,5"/>

            <Button Content="Přidat" Click="Pridat_Click" Margin="0,5"/>
            <Button Content="Načíst" Click="Nacist_Click" Margin="0,5"/>
            <Button Content="Upravit" Click="Upravit_Click" Margin="0,5"/>
            <Button Content="Smazat" Click="Smazat_Click" Margin="0,5"/>
        </StackPanel>
    </Grid>
</Window>